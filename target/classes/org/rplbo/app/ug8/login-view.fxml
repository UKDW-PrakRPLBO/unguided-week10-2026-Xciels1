<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="563.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.rplbo.app.ug8.Controller.LoginController">
    <children>
        <Label alignment="CENTER" contentDisplay="CENTER" layoutX="125.0" layoutY="33.0" text="UMBRELA CORP - SECTOR B">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <VBox layoutX="128.0" layoutY="110.0" prefHeight="55.0" prefWidth="318.0">
            <children>
                <Label text="OPERATIVE ID:" />
                <TextField fx:id="txtUsername" prefWidth="314.0" />
            </children>
        </VBox>

        <VBox layoutX="130.0" layoutY="176.0" prefHeight="48.0" prefWidth="311.0">
            <children>
                <Label text="PASSCODE:" />
                <PasswordField fx:id="txtPassword" prefWidth="308.0" />
            </children>
        </VBox>

        <Button layoutX="226.0" layoutY="253.0" mnemonicParsing="false" onAction="#handleLogin" text="AUTHENTICATE" />

        <Label fx:id="lblStatus" alignment="CENTER" layoutX="128.0" layoutY="300.0" prefHeight="17.0" prefWidth="318.0" textAlignment="CENTER" textFill="RED">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
    </children>
</AnchorPane>